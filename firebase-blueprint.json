{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "Global page texts, visual settings and property catalog for the Havn Proptech platform.",
      "type": "object",
      "properties": {
        "properties": {
          "type": "array",
          "description": "List of real estate properties"
        },
        "pageTexts": {
          "type": "object",
          "description": "Dictionary of text elements for copywriting"
        },
        "brandGreenColor": {
          "type": "string",
          "description": "Primary green branding accent color hex code"
        },
        "brandBgColor": {
          "type": "string",
          "description": "Primary background styling color hex code"
        },
        "selectedFont": {
          "type": "string",
          "description": "Active font face selection"
        },
        "visibleSections": {
          "type": "object",
          "description": "Toggle visibility settings for home layout sections"
        },
        "features": {
          "type": "array",
          "description": "Why Havn promotional benefits list"
        },
        "steps": {
          "type": "array",
          "description": "Buying/selling process sequence journey steps"
        },
        "testimonials": {
          "type": "array",
          "description": "User feedback testimonial cards list"
        },
        "flipData": {
          "type": "object",
          "description": "Investment stats for the Havn Flip section"
        },
        "financingServices": {
          "type": "array",
          "description": "Associated credit and mortgage financing partnerships"
        },
        "adminPassword": {
          "type": "string",
          "description": "Security write gate confirmation value"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 modification timestamp"
        }
      },
      "required": ["adminPassword", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Form submission entries generated by potential buyers and sellers.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "Full name of the contact"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Valid contact email address"
        },
        "phone": {
          "type": "string",
          "minLength": 8,
          "maxLength": 20,
          "description": "Valid telephone or mobile number"
        },
        "intent": {
          "type": "string",
          "enum": ["buy", "sell"],
          "description": "Core customer purpose (buying or selling a property)"
        },
        "budget": {
          "type": "string",
          "description": "Self-selected financial range estimate"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 generation timestamp"
        }
      },
      "required": ["name", "email", "phone", "intent", "createdAt"]
    }
  },
  "firestore": {
    "/settings/main": {
      "schema": "Settings",
      "description": "Primary settings and content management document"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Contact form leads collection"
    }
  }
}
